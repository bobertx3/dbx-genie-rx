# Databricks Apps ignore file
# Controls what files are synced during deployment
# See: https://github.com/databricks-solutions/databricks-genai-app-template

# =============================================================================
# IMPORTANT: dist/ MUST be deployed (it contains the React build)
# package.json and package-lock.json MUST be deployed (Databricks Apps auto-builds)
# =============================================================================

# Development and IDE files
.git/
.vscode/
.cursor/
.idea/
*.pyc
__pycache__/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Environment files (secrets - never deploy these)
.env
.env.local
.env.*

# Frontend source files (not needed at runtime - Databricks Apps builds from package.json)
node_modules/
src/
public/
.vite/
.npmrc

# Frontend config files (not needed at runtime)
tsconfig.json
tsconfig.app.json
tsconfig.node.json
eslint.config.js
vite.config.ts
index.html

# DO NOT ignore package.json or package-lock.json - Databricks Apps needs them for build
# DO NOT ignore dist/ - it contains the React build output

# Test and scratch files
tests/
test_*.py
/scratch/
/output/

# Documentation (not needed at runtime)
/docs/
CLAUDE.md
README.md

# Python virtual environments
.venv/
venv/

# MLflow local runs
mlruns/
